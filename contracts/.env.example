# Used by Foundry deploy scripts (DeployV2.s.sol, DeployMockToken.s.sol)
# Copy to .env and fill in your values before running forge script

# Your admin wallet private key (the one that will own the factory + sign admin txs)
ADMIN_PRIVATE_KEY=0x...

# Optional: Basescan API key for --verify flag (get one at https://basescan.org/myapikey)
ETHERSCAN_API_KEY=

# --- Ethereum Sepolia constants (hardcoded in scripts, listed here for reference) ---
# Uniswap V3 Factory:  0x0227628f3F023bb0B980b67D528571c95c6DaC1c
# WETH:                0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14
# USDC (Circle):       0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# --- Filled in automatically after deployment ---
# Copy these from the forge script output into api/.env

# FACTORY_ADDRESS=0x...       (output of DeployV2.s.sol)
# MOCK_TOKEN_ADDRESS=0x...    (output of DeployMockToken.s.sol)
# MOCK_POOL_ADDRESS=0x...     (output of DeployMockToken.s.sol)
# TOKEN0_IS_QUOTE=true        (output of DeployMockToken.s.sol)
